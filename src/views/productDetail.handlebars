<h2 style="text-align:center;">Detalle del producto</h2>

<div class="container">
  <div class="card">
    <h2>{{product.title}}</h2>
    <p class="price">$ {{product.price}}</p>
    <p>Categoría: {{product.category}}</p>
    <p>Stock: {{product.stock}}</p>

    <button onclick="addToCart('{{product._id}}')">
      Agregar al carrito
    </button>
  </div>
</div>