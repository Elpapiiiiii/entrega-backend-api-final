<h1>Lista de productos</h1>

{{#if products.length}}
  <ul>
    {{#each products}}
      <li>
        ID: {{this.id}} | {{this.title}} | ${{this.price}}
      </li>
    {{/each}}
  </ul>
{{else}}
  <p>No hay productos cargados.</p>
{{/if}}

<a href="/realtimeproducts">Ir a productos en tiempo real</a>